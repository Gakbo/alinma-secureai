# Copy this file to .env and fill in real values before running in production.

# Leave unset to use local SQLite (zero setup, good for demo/dev).
# To use PostgreSQL, uncomment and edit:
# DATABASE_URL=postgresql://alinma_user:password@localhost:5432/alinma_secureai

# JWT signing secret — generate a strong random value for production,
# e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=change-this-to-a-long-random-string
