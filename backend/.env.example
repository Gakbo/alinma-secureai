# Copy this file to backend/.env and fill in real values.
# The backend loads it automatically at startup (python-dotenv).
# NEVER commit the real .env — it is gitignored.

# ── Database ────────────────────────────────────────────────────────────────
# Leave unset to use local SQLite (zero setup, good for demo/dev).
# To use PostgreSQL, uncomment and edit:
# DATABASE_URL=postgresql://alinma_user:password@localhost:5432/alinma_secureai

# ── Auth / JWT ──────────────────────────────────────────────────────────────
# JWT signing secret — generate a strong random value for production,
# e.g. `python -c "import secrets; print(secrets.token_hex(32))"`
SECRET_KEY=change-this-to-a-long-random-string

# ── AI chatbot (optional) ───────────────────────────────────────────────────
# With a key: free-text questions are answered by OpenAI (gpt-4o-mini).
# Without one: the bilingual rule-based IVR menu still answers everything.
# The key stays on the backend only — it is never sent to the browser.
# OPENAI_API_KEY=sk-...

# ── Email / SMTP (optional) ─────────────────────────────────────────────────
# When unset, password-reset links are PRINTED TO THE BACKEND CONSOLE instead
# of being emailed — the reset flow still works in development.
# See docs/smtp-setup.md for Gmail/Resend walkthroughs.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=alerts@example.com
# SMTP_PASS=your-app-password
# SMTP_FROM=alerts@example.com

# Public frontend URL — embedded in the reset link inside every email.
# APP_URL=http://localhost:5173

# ── ML backends (optional) ──────────────────────────────────────────────────
# SMS classifier: auto (transformer -> TF-IDF -> rules) | transformer | tfidf | rules
# MODEL_BACKEND=auto
# Transaction model: auto | model | rules
# TXN_MODEL_BACKEND=auto
# Custom model locations (defaults shown relative to backend/):
# SMS_MODEL_DIR=saved_models/transformer_sms_classifier
# SMS_TFIDF_DIR=saved_models/sms_ml
